<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #E1D4C2;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gibsie.atelier.controller.OrderDetailController">

    <top>
        <VBox style="-fx-background-color: #291C0E;">
            <padding>
                <Insets bottom="15" left="20" right="20" top="15" />
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Button fx:id="backButton" style="-fx-background-color: #6E473B; -fx-text-fill: #E1D4C2;" text="← Назад" />
                <Label text="Индивидуальный заказ" textFill="#E1D4C2">
                    <font>
                        <Font name="System Bold" size="24" />
                    </font>
                </Label>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: #E1D4C2; -fx-background-color: #E1D4C2;">
            <VBox spacing="20">
                <padding>
                    <Insets bottom="20" left="20" right="20" top="20" />
                </padding>

                <HBox spacing="20" alignment="CENTER">
                    <!-- Изображение модели -->
                    <VBox alignment="CENTER" spacing="10" style="-fx-background-color: #BEB5A9; -fx-background-radius: 10; -fx-padding: 20;" prefWidth="300">
                        <ImageView fx:id="modelImageView" fitHeight="250" fitWidth="250" preserveRatio="true" />
                        <Label fx:id="modelNameLabel" style="-fx-font-weight: bold; -fx-font-size: 18;" textFill="#291C0E" />
                        <Label fx:id="modelDescriptionLabel" wrapText="true" textFill="#6E473B" />
                        <Label fx:id="basePriceLabel" style="-fx-font-weight: bold;" textFill="#291C0E" />
                    </VBox>

                    <!-- Форма заказа (упрощенная) -->
                    <VBox spacing="15" style="-fx-background-color: #BEB5A9; -fx-background-radius: 10; -fx-padding: 20;" HBox.hgrow="ALWAYS" prefWidth="400">
                        <Label style="-fx-font-weight: bold; -fx-font-size: 16;" text="Настройка модели" textFill="#291C0E" />

                        <Label text="Выберите цвет:" textFill="#291C0E" />
                        <ComboBox fx:id="colorComboBox" promptText="Выберите цвет" maxWidth="Infinity" style="-fx-background-color: #E1D4C2;" />

                        <Label text="Выберите размер:" textFill="#291C0E" />
                        <ComboBox fx:id="sizeComboBox" promptText="Выберите размер" maxWidth="Infinity" style="-fx-background-color: #E1D4C2;" />

                        <!-- ДОБАВЛЕНО: поле для ввода дополнительных пожеланий -->
                        <Label text="Дополнительные пожелания:" textFill="#291C0E" />
                        <TextArea fx:id="descriptionArea"
                                  promptText="Особенности кроя, декоративные элементы..."
                                  wrapText="true"
                                  prefRowCount="4" style="-fx-background-color: #E1D4C2;" />

                        <Separator />

                        <HBox alignment="CENTER_RIGHT" spacing="20">
                            <Label style="-fx-font-weight: bold;" text="Примерная стоимость:" textFill="#291C0E" />
                            <Label fx:id="estimatedPriceLabel" style="-fx-font-weight: bold; -fx-font-size: 20;" text="0 ₽" textFill="#6E473B" />
                        </HBox>

                        <Button fx:id="submitOrderButton" text="Оформить заказ" maxWidth="Infinity" style="-fx-background-color: #6E473B; -fx-text-fill: #E1D4C2; -fx-font-weight: bold; -fx-padding: 10;" />

                        <Label fx:id="statusLabel" textFill="#6E473B" wrapText="true" />
                    </VBox>
                </HBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>